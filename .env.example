# Copy this to .env and fill in values

# Your Substack session cookie
# How to get it:
#   1. Go to https://themindshareadvisory.substack.com and log in
#   2. Open DevTools (F12) → Application → Cookies → themindshareadvisory.substack.com
#   3. Find the cookie named: substack.sid — copy its Value
#   Refresh every few months when the session expires.
SUBSTACK_SID=your-session-cookie-value-here
